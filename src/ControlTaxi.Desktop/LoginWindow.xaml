<Window x:Class="ControlTaxi.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Acceso HOKA - Control Taxi" Height="640" Width="1040"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        Background="#143F55" FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Caja de texto estilo del login anterior -->
        <Style x:Key="LoginInput" TargetType="Control">
            <Setter Property="Height" Value="50" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#F8FBFD" />
            <Setter Property="Foreground" Value="#152339" />
            <Setter Property="BorderBrush" Value="#C8D6E3" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- Botón verde "Entrar al POS" -->
        <Style x:Key="LoginButton" TargetType="Button">
            <Setter Property="Background" Value="#0F8F83" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Height" Value="54" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#0B766D" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Background" Value="#9AB7B2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Marco crema con la "tarjeta" central, como el shell anterior -->
    <Border Background="#F4F0E8" Padding="18">
        <Border CornerRadius="8" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="14" Opacity="0.22" Color="#14233A" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="0.85*" MinWidth="360" />
                </Grid.ColumnDefinitions>

                <!-- ===== Panel izquierdo (hero) ===== -->
                <Grid Grid.Column="0">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#F40E3A4A" Offset="0" />
                            <GradientStop Color="#E60B6F63" Offset="1" />
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Grid Margin="46">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Marca arriba -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Border Background="#F2FFFFFF" CornerRadius="8" Padding="8" Height="64">
                                <Image Source="/Assets/hoka-logo.png" Stretch="Uniform" />
                            </Border>
                            <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                                <TextBlock Text="GRUPO HOKA" Foreground="White" FontWeight="Bold" FontSize="15" />
                                <TextBlock Text="Control Taxi" Foreground="#ADDBD7" FontWeight="Bold" Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Emblema central -->
                        <Image Grid.Row="1" Source="/Assets/taxi.png" Stretch="Uniform"
                               Width="300" HorizontalAlignment="Center" VerticalAlignment="Center" />

                        <!-- Copy abajo -->
                        <StackPanel Grid.Row="2">
                            <TextBlock Text="CAJA OPERATIVA" Foreground="#F0BD67" FontWeight="Bold"
                                       FontSize="13" Margin="0,0,0,10" />
                            <TextBlock Text="CONTROL TAXI" Foreground="White" FontWeight="Black" FontSize="44" />
                            <TextBlock Text="Operación diaria de taxistas, pagos, cortes y catálogos en un solo sistema."
                                       Foreground="#D8EEE9" FontSize="14" TextWrapping="Wrap"
                                       MaxWidth="460" HorizontalAlignment="Left" Margin="0,14,0,0" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- ===== Tarjeta derecha (formulario) ===== -->
                <Border Grid.Column="1" Background="White">
                    <StackPanel VerticalAlignment="Center" Margin="54,0">
                        <TextBlock Text="BIENVENIDO" Foreground="#0F8F83" FontWeight="Bold" FontSize="13" />
                        <TextBlock Text="Iniciar sesión" Foreground="#14243A" FontWeight="Bold"
                                   FontSize="30" Margin="0,8,0,28" />

                        <TextBlock Text="Usuario" Foreground="#34445A" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBox x:Name="UsuarioBox" Style="{StaticResource LoginInput}"
                                 Text="{Binding NombreUsuario, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Contraseña" Foreground="#34445A" FontWeight="SemiBold" Margin="0,18,0,8" />
                        <PasswordBox x:Name="PasswordBox" Style="{StaticResource LoginInput}"
                                     PasswordChanged="PasswordBox_PasswordChanged" />

                        <Button Margin="0,28,0,0" Style="{StaticResource LoginButton}"
                                Command="{Binding LoginCommand}" IsDefault="True">
                            <Grid Width="240">
                                <TextBlock Text="Entrar al POS" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                <Path Data="M5,12 H18 M13,6 L19,12 L13,18" Stroke="White" StrokeThickness="2.4"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>
                        </Button>

                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#D7263D"
                                   TextWrapping="Wrap" Margin="0,18,0,0" TextAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
