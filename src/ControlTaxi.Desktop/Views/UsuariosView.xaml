<UserControl x:Class="ControlTaxi.Desktop.Views.UsuariosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="580" d:DesignWidth="920"
             FontFamily="{StaticResource UiFont}" Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="EstatusUsuarioBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="11" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource BadgeGreenBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource BadgeGreenFg}" />
            <Setter Property="TextElement.Foreground" Value="{StaticResource BadgeGreenFg}" />
            <Setter Property="TextElement.FontWeight" Value="SemiBold" />
            <Setter Property="TextElement.FontSize" Value="12" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Activo}" Value="False">
                    <Setter Property="Background" Value="{StaticResource BadgeGreyBg}" />
                    <Setter Property="BorderBrush" Value="{StaticResource BadgeGreyFg}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource BadgeGreyFg}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <!-- Lista de usuarios -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Usuarios}"
                      SelectedItem="{Binding UsuarioSeleccionado}"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Usuario" Binding="{Binding NombreUsuario}" Width="130" />
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*" />
                    <DataGridTextColumn Header="Rol" Binding="{Binding RolTexto}" Width="120" />
                    <DataGridTemplateColumn Header="Estatus" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource EstatusUsuarioBadge}">
                                    <TextBlock Text="{Binding EstatusTexto}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Formulario de usuario -->
        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="14,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="+ Nuevo" Style="{StaticResource GhostButton}"
                                Command="{Binding NuevoCommand}" />
                        <TextBlock Text="Datos del usuario" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                    </DockPanel>

                    <TextBlock Text="Usuario" Style="{StaticResource FieldLabel}" />
                    <TextBox Text="{Binding NombreUsuario, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding EsNuevo}" />

                    <TextBlock Text="Nombre completo" Style="{StaticResource FieldLabel}" />
                    <TextBox Text="{Binding Nombre}" />

                    <TextBlock Text="Contraseña" Style="{StaticResource FieldLabel}" />
                    <PasswordBox x:Name="PasswordBox" Height="34" Padding="10,0"
                                 VerticalContentAlignment="Center"
                                 PasswordChanged="PasswordBox_PasswordChanged" />
                    <TextBlock Text="Déjala vacía para no cambiarla al editar."
                               Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,3,0,0" />

                    <TextBlock Text="Rol" Style="{StaticResource FieldLabel}" />
                    <ComboBox ItemsSource="{Binding Roles}" DisplayMemberPath="Texto"
                              SelectedItem="{Binding RolSeleccionado}" />

                    <CheckBox Content="Usuario activo" IsChecked="{Binding Activo}" Margin="0,12,0,0"
                              Foreground="{StaticResource TextPrimary}" />

                    <TextBlock Text="Permisos (qué puede ver)" Style="{StaticResource SectionTitle}" Margin="0,16,0,6" />
                    <TextBlock Text="El rol Administrador puede ver todo, sin importar estas casillas."
                               Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,8" />
                    <Border Background="{StaticResource SurfaceAlt}" CornerRadius="8" Padding="10">
                        <ItemsControl ItemsSource="{Binding Permisos}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Nombre}" IsChecked="{Binding Seleccionado}"
                                              Margin="0,4" Foreground="{StaticResource TextPrimary}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <Button Content="Guardar usuario" Style="{StaticResource PrimaryButton}"
                            Margin="0,16,0,0" Command="{Binding GuardarCommand}" />

                    <TextBlock Text="{Binding Mensaje}" Foreground="{StaticResource Success}"
                               TextWrapping="Wrap" Margin="0,12,0,0" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
