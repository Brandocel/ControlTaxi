<UserControl x:Class="ControlTaxi.Desktop.Views.TaxistasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="960"
             FontFamily="{StaticResource UiFont}" Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Foreground" Value="{StaticResource BrandTeal}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LinkDanger" TargetType="Button" BasedOn="{StaticResource LinkButton}">
            <Setter Property="Foreground" Value="{StaticResource Danger}" />
        </Style>

        <Style x:Key="EstatusTaxistaBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="11" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource BadgeGreenBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource BadgeGreenFg}" />
            <Setter Property="TextElement.Foreground" Value="{StaticResource BadgeGreenFg}" />
            <Setter Property="TextElement.FontWeight" Value="SemiBold" />
            <Setter Property="TextElement.FontSize" Value="12" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Activo}" Value="False">
                    <Setter Property="Background" Value="{StaticResource BadgeGreyBg}" />
                    <Setter Property="BorderBrush" Value="{StaticResource BadgeGreyFg}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource BadgeGreyFg}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <!-- Lista de taxistas -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,14">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <TextBlock Text="Buscar" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0" />
                        <TextBox Width="220" Text="{Binding Busqueda, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="Buscar" Style="{StaticResource PrimaryButton}"
                                Margin="10,0,0,0" Command="{Binding BuscarCommand}" />
                    </StackPanel>
                    <TextBlock Text="{Binding Mensaje}"
                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"
                               TextAlignment="Right" TextTrimming="CharacterEllipsis" Margin="14,0,0,0" />
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                <DataGrid ItemsSource="{Binding Taxistas}" BorderThickness="0" MinColumnWidth="72">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Clave" Binding="{Binding Clave}" Width="78" />
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*" MinWidth="180" />
                        <DataGridTextColumn Header="Unidad" Binding="{Binding Unidad}" Width="88" />
                        <DataGridTextColumn Header="Placas" Binding="{Binding Placas}" Width="96" />
                        <DataGridTextColumn Header="Teléfono" Binding="{Binding Telefono}" Width="118" />
                        <DataGridTemplateColumn Header="Estatus" Width="98">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource EstatusTaxistaBadge}">
                                        <TextBlock Text="{Binding EstatusTexto}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Acción" Width="142">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Editar" Style="{StaticResource LinkButton}"
                                                Command="{Binding DataContext.EditarCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="Eliminar" Style="{StaticResource LinkDanger}"
                                                Click="Eliminar_Click" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- Formulario de taxista -->
        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="14,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="+ Nuevo" Style="{StaticResource GhostButton}"
                                Command="{Binding NuevoCommand}" />
                        <TextBlock Text="Datos del taxista" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                    </DockPanel>

                    <TextBlock Text="Clave" Style="{StaticResource FieldLabel}" />
                    <TextBox Text="{Binding Clave}" IsEnabled="{Binding EsNuevo}" />

                    <TextBlock Text="Nombre" Style="{StaticResource FieldLabel}" />
                    <TextBox Text="{Binding Nombre}" />

                    <TextBlock Text="Teléfono" Style="{StaticResource FieldLabel}" />
                    <TextBox Text="{Binding Telefono}" />

                    <TextBlock Text="Unidad" Style="{StaticResource FieldLabel}" />
                    <TextBox Text="{Binding Unidad}" />

                    <TextBlock Text="Placas" Style="{StaticResource FieldLabel}" />
                    <TextBox Text="{Binding Placas}" />

                    <CheckBox Content="Taxista activo" IsChecked="{Binding Activo}" Margin="0,12,0,0"
                              Foreground="{StaticResource TextPrimary}" />

                    <Button Content="Guardar taxista" Style="{StaticResource PrimaryButton}"
                            Margin="0,16,0,0" Command="{Binding GuardarCommand}" />

                    <TextBlock Text="{Binding Mensaje}" Foreground="{StaticResource Success}"
                               TextWrapping="Wrap" Margin="0,12,0,0" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
