<UserControl x:Class="ControlTaxi.Desktop.Views.RelacionesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="580" d:DesignWidth="920"
             FontFamily="{StaticResource UiFont}" Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Celdas de estatus: color de celda completa, sin capsula -->
        <Style x:Key="CeldaEstatusBase" TargetType="DataGridCell">
            <Setter Property="Background" Value="{StaticResource BadgeGreyBg}" />
            <Setter Property="Foreground" Value="{StaticResource BadgeGreyFg}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="CeldaEstatus" TargetType="DataGridCell" BasedOn="{StaticResource CeldaEstatusBase}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Estatus}" Value="Ligado">
                    <Setter Property="Background" Value="{StaticResource BadgeTealBg}" />
                    <Setter Property="Foreground" Value="{StaticResource BadgeTealFg}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Estatus}" Value="ComisionPendiente">
                    <Setter Property="Background" Value="{StaticResource BadgeAmberBg}" />
                    <Setter Property="Foreground" Value="{StaticResource BadgeAmberFg}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Estatus}" Value="ComisionPagada">
                    <Setter Property="Background" Value="{StaticResource BadgeGreenBg}" />
                    <Setter Property="Foreground" Value="{StaticResource BadgeGreenFg}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CeldaDejada" TargetType="DataGridCell" BasedOn="{StaticResource CeldaEstatusBase}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding EstatusDejada}" Value="Pendiente">
                    <Setter Property="Background" Value="{StaticResource BadgeAmberBg}" />
                    <Setter Property="Foreground" Value="{StaticResource BadgeAmberFg}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding EstatusDejada}" Value="Pagado">
                    <Setter Property="Background" Value="{StaticResource BadgeGreenBg}" />
                    <Setter Property="Foreground" Value="{StaticResource BadgeGreenFg}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TextoCeldaEstatus" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <!-- Barra del skeleton: pulso SOLO de opacidad (no cambia tamano => no descuadra) -->
        <Style x:Key="SkBar" TargetType="Border">
            <Setter Property="Height" Value="12" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{StaticResource SkeletonBar}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="12,0,8,0" />
            <Style.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0.55" To="1" Duration="0:0:1.0"
                                             AutoReverse="True" RepeatBehavior="Forever" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- Una fila del skeleton: MISMAS columnas que la tabla real => alineado -->
        <ControlTemplate x:Key="SkRow" TargetType="Control">
            <Border Height="40" BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="76" />
                        <ColumnDefinition Width="56" />
                        <ColumnDefinition Width="82" />
                        <ColumnDefinition Width="86" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" MinWidth="140" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SkBar}" Width="58" />
                    <Border Grid.Column="1" Style="{StaticResource SkBar}" Width="56" />
                    <Border Grid.Column="2" Style="{StaticResource SkBar}" Width="150" />
                    <Border Grid.Column="3" Style="{StaticResource SkBar}" Width="34" />
                    <Border Grid.Column="4" Style="{StaticResource SkBar}" Width="22" />
                    <Border Grid.Column="5" Style="{StaticResource SkBar}" Width="44" />
                    <Border Grid.Column="6" Style="{StaticResource SkBar}" Width="44" />
                    <Border Grid.Column="7" Style="{StaticResource SkBar}" Width="104" Height="20" CornerRadius="10" />
                    <Border Grid.Column="8" Style="{StaticResource SkBar}" Width="70" Height="20" CornerRadius="10" />
                </Grid>
            </Border>
        </ControlTemplate>

        <!-- Una celda del encabezado replica -->
        <Style x:Key="SkHead" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TableHeaderFg}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="12,0,0,0" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Barra de filtros -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Buscar" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0" />
                <TextBox Width="220" Text="{Binding Busqueda, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Desde" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondary}" Margin="16,0,8,0" />
                <DatePicker Width="130" SelectedDate="{Binding FechaInicio}" />
                <TextBlock Text="Hasta" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondary}" Margin="16,0,8,0" />
                <DatePicker Width="130" SelectedDate="{Binding FechaFin}" />
                <Button Content="Buscar" Style="{StaticResource PrimaryButton}"
                        Margin="16,0,0,0" Command="{Binding BuscarCommand}" />
                <TextBlock Text="{Binding Mensaje}" VerticalAlignment="Center"
                           Foreground="{StaticResource Success}" Margin="16,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Grilla + formulario -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- Contenedor de la tabla con su skeleton encima -->
            <Grid Grid.Column="0">
                <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                    <DataGrid ItemsSource="{Binding Relaciones}"
                              SelectedItem="{Binding RelacionSeleccionada}"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Folio App" Binding="{Binding FolioApp}" Width="100" />
                            <DataGridTextColumn Header="Ticket POS" Binding="{Binding FolioOperacion}" Width="100" />
                            <DataGridTextColumn Header="Taxista" Binding="{Binding TaxistaNombre}" Width="220" />
                            <DataGridTextColumn Header="Transp." Binding="{Binding TransporteTipo}" Width="76" />
                            <DataGridTextColumn Header="Pax" Binding="{Binding Pax}" Width="56"
                                                ElementStyle="{StaticResource CellCenter}" />
                            <DataGridTextColumn Header="Venta" Binding="{Binding Venta, StringFormat=C0}" Width="82"
                                                ElementStyle="{StaticResource CellRight}" />
                            <DataGridTextColumn Header="Dejada" Binding="{Binding Dejada, StringFormat=C0}" Width="86"
                                                ElementStyle="{StaticResource CellRight}" />
                            <DataGridTemplateColumn Header="Estatus" Width="180"
                                                    CellStyle="{StaticResource CeldaEstatus}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding EstatusTexto}"
                                                   Style="{StaticResource TextoCeldaEstatus}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Estado dejada" Width="*" MinWidth="140"
                                                    CellStyle="{StaticResource CeldaDejada}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding EstatusDejadaTexto}"
                                                   Style="{StaticResource TextoCeldaEstatus}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Skeleton de carga: replica EXACTA de la tabla (mismas columnas) -->
                <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <!-- Encabezado replica identico al real -->
                        <Border Background="{StaticResource HeaderDark}" Height="40">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="82" />
                                <ColumnDefinition Width="86" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" MinWidth="140" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Folio App" Style="{StaticResource SkHead}" />
                                <TextBlock Grid.Column="1" Text="Ticket POS" Style="{StaticResource SkHead}" />
                                <TextBlock Grid.Column="2" Text="Taxista" Style="{StaticResource SkHead}" />
                                <TextBlock Grid.Column="3" Text="Transp." Style="{StaticResource SkHead}" />
                                <TextBlock Grid.Column="4" Text="Pax" Style="{StaticResource SkHead}" />
                                <TextBlock Grid.Column="5" Text="Venta" Style="{StaticResource SkHead}" />
                                <TextBlock Grid.Column="6" Text="Dejada" Style="{StaticResource SkHead}" />
                                <TextBlock Grid.Column="7" Text="Estatus" Style="{StaticResource SkHead}" />
                                <TextBlock Grid.Column="8" Text="Estado dejada" Style="{StaticResource SkHead}" />
                            </Grid>
                        </Border>
                        <!-- Filas placeholder -->
                        <Control Template="{StaticResource SkRow}" />
                        <Control Template="{StaticResource SkRow}" />
                        <Control Template="{StaticResource SkRow}" />
                        <Control Template="{StaticResource SkRow}" />
                        <Control Template="{StaticResource SkRow}" />
                        <Control Template="{StaticResource SkRow}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Panel lateral: ligar + cobrar -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="14,0,0,0">
                <StackPanel>
                    <TextBlock Text="Ligar / guardar relacion" Style="{StaticResource SectionTitle}" />

                    <TextBlock Text="Folio App (ticket)" Style="{StaticResource FieldLabel}" />
                    <TextBox Text="{Binding FolioApp}" />

                    <TextBlock Text="Ticket POS" Style="{StaticResource FieldLabel}" />
                    <TextBox Text="{Binding FolioOperacion}" />

                    <TextBlock Text="Buscar taxista" Style="{StaticResource FieldLabel}" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Buscar" Style="{StaticResource GhostButton}"
                                Padding="10,0" Margin="6,0,0,0" Command="{Binding BuscarTaxistasCommand}" />
                        <TextBox Text="{Binding TaxistaQuery, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>
                    <ComboBox Margin="0,6,0,0" DisplayMemberPath="Nombre"
                              ItemsSource="{Binding TaxistaOpciones}"
                              SelectedItem="{Binding TaxistaSeleccionado}" />

                    <TextBlock Text="Transporte / Gafete" Style="{StaticResource FieldLabel}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Margin="0,0,4,0" Text="{Binding TransporteTipo}" />
                        <TextBox Grid.Column="1" Margin="4,0,0,0" Text="{Binding Gafete}" />
                    </Grid>

                    <TextBlock Text="Observaciones" Style="{StaticResource FieldLabel}" />
                    <TextBox Height="52" Padding="8" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalContentAlignment="Top" Text="{Binding Observaciones}" />

                    <Button Content="Guardar relacion" Style="{StaticResource PrimaryButton}"
                            Margin="0,14,0,0" Command="{Binding GuardarCommand}" />

                    <Separator Margin="0,16" Background="{StaticResource BorderSoft}" />

                    <Button Content="Cobrar dejada de la fila seleccionada"
                            Style="{StaticResource GoldButton}" Command="{Binding PagarDejadaCommand}" />
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Margin="2,12,0,0" Foreground="{StaticResource TextMuted}" FontSize="12"
                   Text="Estatus: Pendiente de ligar -> Pendiente de ticket -> Ligado -> Comision pendiente/pagada" />
    </Grid>
</UserControl>

