<UserControl x:Class="ControlTaxi.Desktop.Views.RelacionesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="580" d:DesignWidth="920"
             FontFamily="{StaticResource UiFont}" Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Badge base; el color cambia según el estatus (DataTriggers) -->
        <Style x:Key="BadgeBase" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource BadgeGreyBg}" />
            <Setter Property="TextElement.Foreground" Value="{StaticResource BadgeGreyFg}" />
            <Setter Property="TextElement.FontWeight" Value="SemiBold" />
            <Setter Property="TextElement.FontSize" Value="12" />
        </Style>

        <Style x:Key="EstatusBadge" TargetType="Border" BasedOn="{StaticResource BadgeBase}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Estatus}" Value="Ligado">
                    <Setter Property="Background" Value="{StaticResource BadgeTealBg}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource BadgeTealFg}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Estatus}" Value="ComisionPendiente">
                    <Setter Property="Background" Value="{StaticResource BadgeAmberBg}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource BadgeAmberFg}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Estatus}" Value="ComisionPagada">
                    <Setter Property="Background" Value="{StaticResource BadgeGreenBg}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource BadgeGreenFg}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DejadaBadge" TargetType="Border" BasedOn="{StaticResource BadgeBase}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding EstatusDejada}" Value="Pendiente">
                    <Setter Property="Background" Value="{StaticResource BadgeAmberBg}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource BadgeAmberFg}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding EstatusDejada}" Value="Pagado">
                    <Setter Property="Background" Value="{StaticResource BadgeGreenBg}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource BadgeGreenFg}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Barra del skeleton -->
        <Style x:Key="SkBar" TargetType="Border">
            <Setter Property="Height" Value="13" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{StaticResource SkeletonBar}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,18,0" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Barra de filtros -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Buscar" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0" />
                <TextBox Width="220" Text="{Binding Busqueda, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Desde" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondary}" Margin="16,0,8,0" />
                <DatePicker Width="130" SelectedDate="{Binding FechaInicio}" />
                <TextBlock Text="Hasta" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondary}" Margin="16,0,8,0" />
                <DatePicker Width="130" SelectedDate="{Binding FechaFin}" />
                <Button Content="Buscar" Style="{StaticResource PrimaryButton}"
                        Margin="16,0,0,0" Command="{Binding BuscarCommand}" />
                <TextBlock Text="{Binding Mensaje}" VerticalAlignment="Center"
                           Foreground="{StaticResource Success}" Margin="16,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Grilla + formulario -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- Contenedor de la tabla con su skeleton encima -->
            <Grid Grid.Column="0">
                <Border Style="{StaticResource Card}" Padding="0">
                    <DataGrid ItemsSource="{Binding Relaciones}"
                              SelectedItem="{Binding RelacionSeleccionada}"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Folio App" Binding="{Binding FolioApp}" Width="90" />
                            <DataGridTextColumn Header="Ticket POS" Binding="{Binding FolioOperacion}" Width="90" />
                            <DataGridTextColumn Header="Taxista" Binding="{Binding TaxistaNombre}" Width="*" />
                            <DataGridTextColumn Header="Transp." Binding="{Binding TransporteTipo}" Width="64" />
                            <DataGridTextColumn Header="Pax" Binding="{Binding Pax}" Width="48" />
                            <DataGridTextColumn Header="Venta" Binding="{Binding Venta, StringFormat=C0}" Width="76" />
                            <DataGridTextColumn Header="Dejada" Binding="{Binding Dejada, StringFormat=C0}" Width="76" />
                            <DataGridTemplateColumn Header="Estatus" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource EstatusBadge}">
                                            <TextBlock Text="{Binding EstatusTexto}" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Estado dejada" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource DejadaBadge}">
                                            <TextBlock Text="{Binding EstatusDejadaTexto}" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Skeleton de carga (se muestra mientras IsBusy) -->
                <Border Style="{StaticResource Card}" Padding="0"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Border.Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.5" To="1" Duration="0:0:0.85"
                                                     AutoReverse="True" RepeatBehavior="Forever" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <StackPanel Margin="0">
                        <!-- Encabezado simulado -->
                        <Border Background="{StaticResource HeaderDark}" Height="40" CornerRadius="10,10,0,0" />
                        <ItemsControl Margin="16,8">
                            <ItemsControl.Resources>
                                <Style TargetType="Grid">
                                    <Setter Property="Height" Value="40" />
                                </Style>
                            </ItemsControl.Resources>
                            <!-- Cada fila del skeleton -->
                            <Grid><StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource SkBar}" Width="70" /><Border Style="{StaticResource SkBar}" Width="70" />
                                <Border Style="{StaticResource SkBar}" Width="200" /><Border Style="{StaticResource SkBar}" Width="50" />
                                <Border Style="{StaticResource SkBar}" Width="70" /><Border Style="{StaticResource SkBar}" Width="120" /></StackPanel></Grid>
                            <Grid><StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource SkBar}" Width="70" /><Border Style="{StaticResource SkBar}" Width="70" />
                                <Border Style="{StaticResource SkBar}" Width="160" /><Border Style="{StaticResource SkBar}" Width="50" />
                                <Border Style="{StaticResource SkBar}" Width="70" /><Border Style="{StaticResource SkBar}" Width="120" /></StackPanel></Grid>
                            <Grid><StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource SkBar}" Width="70" /><Border Style="{StaticResource SkBar}" Width="70" />
                                <Border Style="{StaticResource SkBar}" Width="220" /><Border Style="{StaticResource SkBar}" Width="50" />
                                <Border Style="{StaticResource SkBar}" Width="70" /><Border Style="{StaticResource SkBar}" Width="120" /></StackPanel></Grid>
                            <Grid><StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource SkBar}" Width="70" /><Border Style="{StaticResource SkBar}" Width="70" />
                                <Border Style="{StaticResource SkBar}" Width="180" /><Border Style="{StaticResource SkBar}" Width="50" />
                                <Border Style="{StaticResource SkBar}" Width="70" /><Border Style="{StaticResource SkBar}" Width="120" /></StackPanel></Grid>
                            <Grid><StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource SkBar}" Width="70" /><Border Style="{StaticResource SkBar}" Width="70" />
                                <Border Style="{StaticResource SkBar}" Width="200" /><Border Style="{StaticResource SkBar}" Width="50" />
                                <Border Style="{StaticResource SkBar}" Width="70" /><Border Style="{StaticResource SkBar}" Width="120" /></StackPanel></Grid>
                            <Grid><StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource SkBar}" Width="70" /><Border Style="{StaticResource SkBar}" Width="70" />
                                <Border Style="{StaticResource SkBar}" Width="150" /><Border Style="{StaticResource SkBar}" Width="50" />
                                <Border Style="{StaticResource SkBar}" Width="70" /><Border Style="{StaticResource SkBar}" Width="120" /></StackPanel></Grid>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Panel lateral: ligar + cobrar -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="14,0,0,0">
                <StackPanel>
                    <TextBlock Text="Ligar / guardar relación" Style="{StaticResource SectionTitle}" />

                    <TextBlock Text="Folio App (ticket)" Style="{StaticResource FieldLabel}" />
                    <TextBox Text="{Binding FolioApp}" />

                    <TextBlock Text="Ticket POS" Style="{StaticResource FieldLabel}" />
                    <TextBox Text="{Binding FolioOperacion}" />

                    <TextBlock Text="Buscar taxista" Style="{StaticResource FieldLabel}" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="🔍" Style="{StaticResource GhostButton}"
                                Padding="10,0" Margin="6,0,0,0" Command="{Binding BuscarTaxistasCommand}" />
                        <TextBox Text="{Binding TaxistaQuery, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>
                    <ComboBox Margin="0,6,0,0" DisplayMemberPath="Nombre"
                              ItemsSource="{Binding TaxistaOpciones}"
                              SelectedItem="{Binding TaxistaSeleccionado}" />

                    <TextBlock Text="Transporte / Gafete" Style="{StaticResource FieldLabel}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Margin="0,0,4,0" Text="{Binding TransporteTipo}" />
                        <TextBox Grid.Column="1" Margin="4,0,0,0" Text="{Binding Gafete}" />
                    </Grid>

                    <TextBlock Text="Observaciones" Style="{StaticResource FieldLabel}" />
                    <TextBox Height="52" Padding="8" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalContentAlignment="Top" Text="{Binding Observaciones}" />

                    <Button Content="Guardar relación" Style="{StaticResource PrimaryButton}"
                            Margin="0,14,0,0" Command="{Binding GuardarCommand}" />

                    <Separator Margin="0,16" Background="{StaticResource BorderSoft}" />

                    <Button Content="Cobrar dejada de la fila seleccionada"
                            Style="{StaticResource GoldButton}" Command="{Binding PagarDejadaCommand}" />
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Margin="2,12,0,0" Foreground="{StaticResource TextMuted}" FontSize="12"
                   Text="Estatus: Pendiente de ligar → Pendiente de ticket → Ligado → Comisión pendiente/pagada" />
    </Grid>
</UserControl>
